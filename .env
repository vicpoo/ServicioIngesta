# .env ingesta-iot
PORT=8001

# Postgres (Neon)
DATABASE_URL=postgresql://neondb_owner:npg_y8w4RBLTnCjS@ep-withered-fog-ajqawsrq-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# MQTT (mismo broker/credenciales que ya usa el ESP32 para publicar).
# El puerto AMQP 5672 no está expuesto, así que Ingesta consume por MQTT
# directo (infrastructure/mqtt), no por AMQP puro.
MQTT_HOST=167.86.81.173
MQTT_PORT=1883
MQTT_USER=kajve
MQTT_PASS=reyhades2005

# Redis (canal de tiempo real hacia el WebSocket Gateway de api-mobile).
# Opcional por ahora: si no está disponible, el servicio arranca igual.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# RabbitMQ - drenado por API HTTP de administración (backlog de kajve_datos).
# Mismo usuario/contraseña que MQTT. Panel: https://rabbitmqtt.dnc-ed-denz.shop
RABBITMQ_MGMT_URL=https://rabbitmqtt.dnc-ed-denz.shop
RABBITMQ_MGMT_USER=kajve
RABBITMQ_MGMT_PASS=reyhades2005
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=kajve_datos
RABBITMQ_POLL_INTERVAL_SECONDS=5